{
  "name": "kip-mcp-server",
  "version": "0.0.0-development",
  "description": "An MCP server that reads your boat's Signal K data and helps AI assistants design and install KIP dashboards.",
  "homepage": "https://github.com/dillan/kip-mcp-server#readme",
  "mcpName": "io.github.dillan/kip-mcp-server",
  "type": "module",
  "bin": {
    "kip-mcp-server": "dist/index.js",
    "kip-mcp-http": "dist/http-server.js"
  },
  "files": [
    "dist/",
    "src/resources/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "inspect:http": "npm run build && npx @modelcontextprotocol/inspector node dist/http-server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "smoke": "node scripts/smoke.mjs",
    "smoke:http": "node scripts/smoke-http.mjs",
    "schema:refresh": "node scripts/refresh-schema.mjs",
    "registry:sync": "node scripts/sync-server-json-version.mjs",
    "docs:tools": "node scripts/gen-tool-reference.mjs",
    "docs:check": "node scripts/gen-tool-reference.mjs --check",
    "ci": "npm run format:check && npm run typecheck && npm run lint && npm run build && npm run docs:check && npm run test:coverage && npm run smoke && npm run smoke:http",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mjs,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "signalk",
    "kip",
    "mcp",
    "marine",
    "dashboard",
    "model-context-protocol",
    "claude",
    "ai",
    "boat",
    "sailing"
  ],
  "license": "MIT",
  "author": "Dillan Laughlin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dillan/kip-mcp-server.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "lodash": "^4.18.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  }
}
