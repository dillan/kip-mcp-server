# Copy this file to .env and fill in your boat's details. The server reads these
# settings at startup. You can also set them in your AI assistant's MCP config
# instead of a .env file.

# Your Signal K server address usually looks like http://your-boat:3000.
SIGNALK_HOST=localhost
SIGNALK_PORT=3000

# Set to true if your Signal K server uses https.
SIGNALK_TLS=false

# Reading data needs no login. To WRITE dashboards, authenticate one of two ways.
# Either a Signal K token...
# SIGNALK_TOKEN=your-signalk-token

# ...or a username and password (the server logs in for you and reuses the token).
# SIGNALK_USER=your-username
# SIGNALK_PASSWORD=your-password

# Override where KIP is served, only if it isn't at <signalk>/@mxtommy/kip/.
# KIP_URL=http://your-boat:3000/@mxtommy/kip/
